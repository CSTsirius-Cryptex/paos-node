# PAOS Node 設定
# 填完後存成 .env，重啟 Node 生效

# ── Central 連線 ─────────────────────────────
CENTRAL_URL=https://paos-central-production.up.railway.app
CENTRAL_OWNER_TOKEN=   # 擁有者 JWT，登入 Central 後從 /auth/verify-otp 取得

# ── 本機設定 ─────────────────────────────────
NODE_PORT=3100
NODE_PUBLIC_URL=       # Tailscale Funnel URL（安裝精靈自動填入）

# ── Obsidian Vault ────────────────────────────
VAULT_PATH=C:/Users/User/SecondBrain

# ── PAOS API Key（本地保護用）────────────────
PAOS_API_KEY=paos-node-local-key
